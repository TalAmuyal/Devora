{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "allow-create-pty",
    "allow-write-pty",
    "allow-resize-pty",
    "allow-close-pty",
    "allow-list-profiles",
    "allow-register-profile",
    "allow-unregister-profile",
    "allow-validate-profile-path",
    "allow-list-workspaces",
    "allow-get-workspace-status",
    "allow-get-all-workspace-statuses",
    "allow-get-registered-repos",
    "allow-get-default-app",
    "allow-get-claude-settings",
    "allow-set-claude-setting",
    "allow-create-workspace",
    "allow-cancel-workspace-creation",
    "allow-add-repo-to-workspace",
    "allow-save-profiling-report",
    "allow-log-error",
    "allow-read-text-file",
    "allow-get-user-guide-path",
    "allow-get-theme",
    "allow-crit-overlay-dismissed",
    "allow---test-report",
    "allow-remove-task",
    "allow-prepare-repurpose-task",
    "allow-repurpose-task",
    "allow-delete-workspace"
  ]
}
