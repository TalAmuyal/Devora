{
  "productName": "Devora Ember",
  "version": "0.1.0",
  "identifier": "com.devora-org.devora-ember",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "create": false,
        "title": "Devora Ember",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost; frame-src http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
