#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE:-$0}")" &>/dev/null && pwd)

# Resolve the underlying crit binary. In the bundled app it is a sibling of
# this wrapper; in the Ember dev environment it may only be on PATH (e.g. in
# OG Devora's bundled-apps directory).
if [[ -x "$SCRIPT_DIR/original-crit" ]]; then
  ORIGINAL_CRIT="$SCRIPT_DIR/original-crit"
else
  ORIGINAL_CRIT=$(command -v original-crit 2>/dev/null || true)
  if [[ -z "$ORIGINAL_CRIT" ]]; then
    echo "crit: cannot find original-crit (not in $SCRIPT_DIR nor on PATH)" >&2
    exit 1
  fi
fi

# Pass non-UI commands directly through to the original binary.
case "${1:-}" in
  comment|share|unpublish|pull|push|stop|status|cleanup|config|install|help|--help|-h|--version)
    exec "$ORIGINAL_CRIT" "$@"
    ;;
esac

OPEN_MODE=$(debi get-conf review.open-mode 2>/dev/null || echo "tab")

if [[ "${DEVORA_EMBER:-}" == "1" ]]; then
  IPC_PORT="${DEVORA_IPC_PORT:-}"
  PTY_ID="${DEVORA_PTY_ID:-}"

  if [[ -z "$IPC_PORT" || -z "$PTY_ID" ]]; then
    # Fallback to original-crit with browser
    EMBER_CRIT=$(command -v original-crit 2>/dev/null || true)
    [[ -n "$EMBER_CRIT" ]] && exec "$EMBER_CRIT" "$@"
    exit 1
  fi

  STDERR_FILE=$(mktemp)
  STDOUT_FILE=$(mktemp)
  STDIN_FILE=""
  OPEN_RESULT_FILE=$(mktemp)
  FAKE_OPEN_DIR=$(mktemp -d)
  CRIT_PID=""
  CURL_PID=""

  ember_cleanup() {
    if [[ -n "$CRIT_PID" ]] && kill -0 "$CRIT_PID" 2>/dev/null; then
      kill "$CRIT_PID" 2>/dev/null || true
      wait "$CRIT_PID" 2>/dev/null || true
    fi
    if [[ -n "$CURL_PID" ]] && kill -0 "$CURL_PID" 2>/dev/null; then
      kill "$CURL_PID" 2>/dev/null || true
      wait "$CURL_PID" 2>/dev/null || true
    fi
    rm -f "$STDERR_FILE" "$STDOUT_FILE" "$OPEN_RESULT_FILE"
    [[ -n "$STDIN_FILE" ]] && rm -f "$STDIN_FILE"
    rm -rf "$FAKE_OPEN_DIR"
  }
  trap ember_cleanup EXIT

  # Shadow 'open' and 'xdg-open' so crit's openBrowser() is a no-op.
  printf '#!/bin/sh\nexit 0\n' > "$FAKE_OPEN_DIR/open"
  printf '#!/bin/sh\nexit 0\n' > "$FAKE_OPEN_DIR/xdg-open"
  chmod +x "$FAKE_OPEN_DIR/open" "$FAKE_OPEN_DIR/xdg-open"
  export PATH="$FAKE_OPEN_DIR:$PATH"

  emit_ask() {
    printf '{"hookSpecificOutput":{"hookEventName":"PermissionRequest","decision":{"behavior":"ask","message":"%s"}}}\n' "$1"
  }

  is_plan_hook=false
  if [[ "${1:-}" == "plan-hook" ]]; then
    is_plan_hook=true
    shift
  fi

  if $is_plan_hook; then
    STDIN_FILE=$(mktemp)
    cat > "$STDIN_FILE"
    "$ORIGINAL_CRIT" plan-hook "$@" < "$STDIN_FILE" > "$STDOUT_FILE" 2> "$STDERR_FILE" &
    CRIT_PID=$!
  else
    "$ORIGINAL_CRIT" --no-open "$@" > "$STDOUT_FILE" 2> "$STDERR_FILE" &
    CRIT_PID=$!
  fi

  # Wait for crit to print the port to stderr.
  PORT=""
  for _ in $(seq 1 100); do
    PORT=$(grep -oE 'port [0-9]+|localhost:[0-9]+' "$STDERR_FILE" 2>/dev/null | head -1 | grep -oE '[0-9]+$' || true)
    [[ -n "$PORT" ]] && break
    if ! kill -0 "$CRIT_PID" 2>/dev/null; then
      wait "$CRIT_PID" 2>/dev/null
      crit_exit=$?
      cat "$STDERR_FILE" >&2
      cat "$STDOUT_FILE"
      if $is_plan_hook && [[ ! -s "$STDOUT_FILE" ]]; then
        echo '{"hookSpecificOutput":{"hookEventName":"PermissionRequest","decision":{"behavior":"allow"}}}'
      fi
      exit "$crit_exit"
    fi
    sleep 0.1
  done

  if [[ -z "$PORT" ]]; then
    cat "$STDERR_FILE" >&2
    if $is_plan_hook; then
      emit_ask "Crit failed to start. Approve exiting plan mode without review?"
    fi
    exit 1
  fi

  # Poll until the crit server is ready to serve the UI
  for _ in $(seq 1 100); do
    if curl -sf "http://localhost:$PORT/api/health" >/dev/null 2>&1; then
      break
    fi
    if ! kill -0 "$CRIT_PID" 2>/dev/null; then
      cat "$STDERR_FILE" >&2
      if $is_plan_hook; then
        emit_ask "Crit daemon died before becoming ready. Approve exiting plan mode without review?"
      fi
      exit 1
    fi
    sleep 0.1
  done

  # Tell Ember to open the overlay. The curl blocks until the overlay is
  # resolved. We run it in the background so we can also watch for crit to
  # exit (user clicked "Finish Review" in Crit's own UI).
  curl -sf -X POST "http://127.0.0.1:$IPC_PORT/crit/open" \
    -H "Content-Type: application/json" \
    -d "{\"ptyId\":$PTY_ID,\"url\":\"http://localhost:$PORT\"}" \
    -o "$OPEN_RESULT_FILE" 2>/dev/null &
  CURL_PID=$!

  # Watch for either crit to exit or curl to return (overlay dismissed).
  while kill -0 "$CRIT_PID" 2>/dev/null && kill -0 "$CURL_PID" 2>/dev/null; do
    sleep 0.5
  done

  if ! kill -0 "$CRIT_PID" 2>/dev/null; then
    # Crit finished (user clicked "Finish Review") — tell Ember to close overlay.
    wait "$CRIT_PID" 2>/dev/null
    CRIT_EXIT=$?
    curl -sf -X POST "http://127.0.0.1:$IPC_PORT/crit/done" \
      -H "Content-Type: application/json" \
      -d "{\"ptyId\":$PTY_ID,\"reason\":\"submitted\"}" >/dev/null 2>&1 || true
    wait "$CURL_PID" 2>/dev/null || true
    cat "$STDOUT_FILE"
    exit "$CRIT_EXIT"
  else
    # Curl returned (overlay was dismissed by user in Ember).
    wait "$CURL_PID" 2>/dev/null || true
    RESULT=$(grep -oE '"result":"[^"]*"' "$OPEN_RESULT_FILE" 2>/dev/null | head -1 | sed 's/"result":"//;s/"//' || echo "dismissed")
    kill "$CRIT_PID" 2>/dev/null || true
    wait "$CRIT_PID" 2>/dev/null || true

    if [[ "$RESULT" == "dismissed" ]]; then
      if $is_plan_hook; then
        emit_ask "Review closed without completing. Approve exiting plan mode?"
      fi
      exit 0
    fi

    # "crashed" or unexpected — output whatever crit produced.
    cat "$STDOUT_FILE"
    exit 0
  fi
fi

if [[ "$OPEN_MODE" == "browser" ]]; then
  exec "$ORIGINAL_CRIT" "$@"
fi

STDERR_FILE=$(mktemp)
STDOUT_FILE=$(mktemp)
STDIN_FILE=""
FAKE_OPEN_DIR=$(mktemp -d)
CRIT_PID=""
WINDOW_ID=""

cleanup() {
  if [[ -n "$CRIT_PID" ]] && kill -0 "$CRIT_PID" 2>/dev/null; then
    kill "$CRIT_PID" 2>/dev/null || true
    wait "$CRIT_PID" 2>/dev/null || true
  fi
  if [[ -n "$WINDOW_ID" ]]; then
    kitty @ close-window --match "id:$WINDOW_ID" 2>/dev/null || true
  fi
  rm -f "$STDERR_FILE" "$STDOUT_FILE"
  [[ -n "$STDIN_FILE" ]] && rm -f "$STDIN_FILE"
  rm -rf "$FAKE_OPEN_DIR"
}
trap cleanup EXIT

# Shadow 'open' and 'xdg-open' so crit's openBrowser() is a no-op.
# plan-hook hardcodes browser opening — this is the only way to suppress it.
printf '#!/bin/sh\nexit 0\n' > "$FAKE_OPEN_DIR/open"
printf '#!/bin/sh\nexit 0\n' > "$FAKE_OPEN_DIR/xdg-open"
chmod +x "$FAKE_OPEN_DIR/open" "$FAKE_OPEN_DIR/xdg-open"
export PATH="$FAKE_OPEN_DIR:$PATH"

emit_ask() {
  printf '{"hookSpecificOutput":{"hookEventName":"PermissionRequest","decision":{"behavior":"ask","message":"%s"}}}\n' "$1"
}

is_plan_hook=false
if [[ "${1:-}" == "plan-hook" ]]; then
  is_plan_hook=true
  shift
fi

if $is_plan_hook; then
  # plan-hook reads JSON from stdin (the hook event).
  # Save it to a file since we need to run crit in the background.
  STDIN_FILE=$(mktemp)
  cat > "$STDIN_FILE"
  "$ORIGINAL_CRIT" plan-hook "$@" < "$STDIN_FILE" > "$STDOUT_FILE" 2> "$STDERR_FILE" &
  CRIT_PID=$!
else
  "$ORIGINAL_CRIT" --no-open "$@" > "$STDOUT_FILE" 2> "$STDERR_FILE" &
  CRIT_PID=$!
fi

# Wait for crit to print the port to stderr.
# Formats: "...on port N..." (<=0.10.1) or "...http://localhost:N..." (>=0.10.4)
PORT=""
for _ in $(seq 1 100); do
  PORT=$(grep -oE 'port [0-9]+|localhost:[0-9]+' "$STDERR_FILE" 2>/dev/null | head -1 | grep -oE '[0-9]+$' || true)
  [[ -n "$PORT" ]] && break
  if ! kill -0 "$CRIT_PID" 2>/dev/null; then
    wait "$CRIT_PID" 2>/dev/null
    crit_exit=$?
    cat "$STDERR_FILE" >&2
    cat "$STDOUT_FILE"
    if $is_plan_hook && [[ ! -s "$STDOUT_FILE" ]]; then
      echo '{"hookSpecificOutput":{"hookEventName":"PermissionRequest","decision":{"behavior":"allow"}}}'
    fi
    exit "$crit_exit"
  fi
  sleep 0.1
done

if [[ -z "$PORT" ]]; then
  echo "crit: failed to detect crit port within 10s" >&2
  cat "$STDERR_FILE" >&2
  if $is_plan_hook; then
    emit_ask "Crit failed to start. Approve exiting plan mode without review?"
  fi
  exit 1
fi

# Poll until the crit server is ready to serve the UI
for _ in $(seq 1 100); do
  if curl -sf "http://localhost:$PORT/api/health" >/dev/null 2>&1; then
    break
  fi
  if ! kill -0 "$CRIT_PID" 2>/dev/null; then
    echo "crit: daemon died before becoming ready" >&2
    cat "$STDERR_FILE" >&2
    if $is_plan_hook; then
      emit_ask "Crit daemon died before becoming ready. Approve exiting plan mode without review?"
    fi
    exit 1
  fi
  sleep 0.1
done

case "$OPEN_MODE" in
  overlay)
    WINDOW_ID=$(kitty @ launch --type=overlay-main glimpse-tty --ctrl-c-copy "http://localhost:$PORT")
    ;;
  *)
    WINDOW_ID=$(kitty @ launch --type=tab --tab-title "[Crit]" glimpse-tty --ctrl-c-copy "http://localhost:$PORT")
    ;;
esac

# Wait for either crit to finish (review done) or the overlay to close (user dismissed).
while kill -0 "$CRIT_PID" 2>/dev/null; do
  if ! kitty @ ls --match "id:${WINDOW_ID}" >/dev/null 2>&1; then
    WINDOW_ID=""
    kill "$CRIT_PID" 2>/dev/null || true
    wait "$CRIT_PID" 2>/dev/null || true
    if $is_plan_hook; then
      # User dismissed the review window — ask whether to proceed without review
      emit_ask "Review window closed without completing the review. Approve exiting plan mode?"
    fi
    exit 0
  fi
  sleep 0.5
done

# Crit finished (user clicked "Finish Review") — close the overlay
kitty @ close-window --match "id:$WINDOW_ID" 2>/dev/null || true
WINDOW_ID=""

wait "$CRIT_PID" 2>/dev/null
CRIT_EXIT=$?

cat "$STDOUT_FILE"
exit "$CRIT_EXIT"
